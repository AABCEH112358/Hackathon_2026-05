# Neon Postgres (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# GitHub API (raises rate limit from 60/hr to 5000/hr)
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API (context agent — analyzer + prompt writer)
OPENAI_API_KEY=sk-your_key_here

# Ingestion defaults (seed uses 100 for dev validation; prod: 5000)
GITHUB_SEED_LIMIT=100

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Layout grid (isometric map tiles)
LAYOUT_GRID_SIZE=64

# CORS (comma-separated; Vite default is :5173, Next.js is :3000)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Logging
LOG_LEVEL=INFO
